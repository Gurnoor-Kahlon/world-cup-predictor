# Example environment configuration for World Cup Match Predictor.
# Copy to ".env" and adjust. All values are OPTIONAL — the project runs with
# sensible defaults and bundled sample data if this file is absent.

# Path to a custom matches CSV. If set and the file exists, it overrides the
# automatic sample/processed-data detection. Must use the standard schema
# (see docs/data_sources.md).
WCP_MATCHES_PATH=

# Port for the Streamlit app and/or FastAPI server.
PORT=8501
